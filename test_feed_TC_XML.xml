<?xml version="1.0" encoding="UTF-8"?>
<!--
  ================================================================
  PRODUCT FEED TEST FILE
  Test Cases: TC_XML_005 to TC_XML_050
  Generated : 2026-06-06
  Based on  : my_product_feed.xml (Fastrack Eyewear feed structure)
  ================================================================

  IMPORTANT NOTES:
  ─────────────────────────────────────────────────────────────────
  TC_XML_028 (Malformed XML):
    Cannot be included in a valid XML file.
    To test, create a SEPARATE file (e.g., tc_xml_028_malformed.xml)
    with a missing closing tag, for example:
      Expected result: Feed validation fails with a proper error message.

  TC_XML_023 (Large Feed / 1000 products):
    This file includes a representative sample (template + extras).
    To simulate 1000 products, duplicate TC_XML_023_TEMPLATE
    items with unique IDs using a feed generator script.
  ─────────────────────────────────────────────────────────────────
-->
<rss version="2.0" xmlns:g="http://base.google.com/ns/1.0">
  <channel>
    <title>Test Product Feed TC_XML_005 to TC_XML_050</title>
    <link>https://example.com</link>
    <description>XML test feed covering repeated nodes, special values, image links, similar node names and cross-column contamination.</description>

    <!-- ============================================================
         TC_XML_005 | Duplicate Values
         Input   : <g:color>Red</g:color><g:color>Red</g:color>
         Expected: Color column contains "Red,Red"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_006 | Empty Repeated Node
         Input   : <g:color>Red</g:color><g:color></g:color>
         Expected: Feed processes successfully; empty value handled per config
         ============================================================ -->
    <!-- ============================================================
         TC_XML_007 | Missing Node
         Input   : No g:color node present
         Expected: Feed processes successfully; Color column remains blank
         ============================================================ -->
    <!-- ============================================================
         TC_XML_008 | Repeated Node Order Preservation
         Input   : <g:size>L</g:size><g:size>M</g:size><g:size>S</g:size>
         Expected: Size column contains "L,M,S"
         ============================================================ -->
   <!-- ============================================================
         TC_XML_009 | Repeated Nodes Separated by Other Nodes
         Input   : <g:color>Red</g:color><g:size>M</g:size><g:color>Blue</g:color>
         Expected: Color column = "Red,Blue"; Size column = "M"
         ============================================================ -->
   <!-- ============================================================
         TC_XML_010 | Special Characters in Node Value
         Input   : <g:title>Men's T-Shirt &amp; Jeans</g:title>
         Expected: Value displayed correctly as "Men's T-Shirt & Jeans"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_011 | XML Entities
         Input   : <g:title>Tom &amp; Jerry</g:title>
         Expected: Output displays "Tom & Jerry"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_012 | Unicode Values
         Input   : <g:title>नमस्ते</g:title>
         Expected: Unicode (UTF-8) text displayed correctly
         ============================================================ -->
    <!-- ============================================================
         TC_XML_013 | Long Node Value
         Input   : ~1000-character description value
         Expected: Complete value stored without truncation
         ============================================================ -->
    <!-- ============================================================
         TC_XML_014 | Node Value Containing Comma
         Input   : <g:title>Red, Blue Shirt</g:title>
         Expected: Entire value "Red, Blue Shirt" stored correctly
         ============================================================ -->
    <!-- ============================================================
         TC_XML_015 | CDATA Content
         Input   : <g:description><![CDATA[Special Offer]]></g:description>
         Expected: Description contains "Special Offer"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_016 | High Occurrence Count
         Input   : <g:size>S1</g:size> ... <g:size>S10</g:size> (10 nodes)
         Expected: All 10 values appear in Size column (S1,S2,...,S10)
         ============================================================ -->
    <!-- ============================================================
         TC_XML_017 | Multiple Products
         Product A has 2 colors; Product B has 3 colors
         Expected: Each product retains its own color values
         ============================================================ -->
    <!-- ============================================================
         TC_XML_018 | Product Isolation
         Product A: Red, Blue  |  Product B: Green only
         Expected: Product B contains only "Green"; no Red or Blue leaks in
         ============================================================ -->
    <!-- ============================================================
         TC_XML_019 | Mixed Repeated and Non-Repeated Nodes
         Input   : Single title node + two g:color nodes
         Expected: Title mapped correctly; Colors aggregated as "Red,Green"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_020 | Unknown Node
         Input   : <g:custom_attribute>ABC</g:custom_attribute>
         Expected: Feed processes successfully; supported nodes unaffected
         ============================================================ -->
    <!-- ============================================================
         TC_XML_021 | Node Names with Different Cases
         Input   : <g:Color>Red</g:Color> and <g:color>Blue</g:color>
         Expected: Processed according to feed specification (case-sensitive)
         NOTE: g:Color (capital C) and g:color are different XML elements
         ============================================================ -->
    <!-- ============================================================
         TC_XML_022 | Namespace Node Parsing
         Input   : <g:color>Red</g:color>
         Expected: Namespace-prefixed node value mapped correctly
         ============================================================ -->
    <!-- ============================================================
         TC_XML_023 | Large Feed Processing (Performance)
         Input   : 1000+ products with repeated nodes
         Expected: Feed processed successfully within acceptable time
         NOTE: This file includes a template product + 5 sample products.
               Use a script to duplicate TC_XML_023_TEMPLATE to 1000 items.
         ============================================================ -->
    <!-- ============================================================
         TC_XML_024 | Feed Reprocessing
         Input   : Product with repeated g:color nodes (Red, Blue)
         Expected: Same values appear after reprocessing the feed
         ============================================================ -->
    <!-- ============================================================
         TC_XML_025 | Multiple Repeated Attributes
         Input   : Color×2, Size×3, Material×2
         Expected: Color="Red,Green" | Size="S,M,L" | Material="Cotton,Polyester"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_026 | Cross-Node Contamination Check
         Input   : g:color=Red,Blue and g:size=S,M
         Expected: Color column contains ONLY "Red,Blue"; Size column contains ONLY "S,M"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_027 | Blank Occurrence in Between
         Input   : <g:color>Red</g:color><g:color></g:color><g:color>Blue</g:color>
         Expected: Blank handled per config; valid values Red and Blue preserved
         ============================================================ -->
    <!-- ============================================================
         TC_XML_028 | Malformed XML  ← SEE HEADER NOTE
         This test case CANNOT be embedded in a valid XML file.
         Create a separate file: tc_xml_028_malformed.xml
         Example malformed content:
           Expected: Feed validation fails with proper error message.
         ============================================================ -->

    <!-- ============================================================
         TC_XML_029 | XML vs CSV Parity
         Input   : A well-structured product in XML
         Expected: Output identical to equivalent CSV row
         ============================================================ -->
    <!-- ============================================================
         TC_XML_030 | Node Sequence Variation
         Input   : g:size appears before id; g:color appears after title
         Expected: All values mapped correctly regardless of node order
         ============================================================ -->
    <!-- ============================================================
         TC_XML_031 | Single Additional Image Link
         Input   : One g:additional_image_link node
         Expected: Additional Image Link column contains the URL
         ============================================================ -->
    <!-- ============================================================
         TC_XML_032 | Multiple Additional Image Links
         Input   : Two g:additional_image_link nodes
         Expected: Column contains "img1.jpg,img2.jpg"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_033 | Five Additional Image Links
         Input   : Five g:additional_image_link nodes
         Expected: All 5 URLs present in output
         ============================================================ -->
    <!-- ============================================================
         TC_XML_034 | Duplicate Additional Image Links
         Input   : img1.jpg repeated twice in g:additional_image_link
         Expected: Output contains "img1.jpg,img1.jpg" (duplicates preserved)
         ============================================================ -->
    <!-- ============================================================
         TC_XML_035 | Empty Additional Image Link
         Input   : One valid URL + one empty g:additional_image_link
         Expected: Feed processes successfully; valid URL remains available
         ============================================================ -->
    <!-- ============================================================
         TC_XML_036 | Missing Additional Image Link
         Input   : No g:additional_image_link node
         Expected: Feed processes successfully without errors
         ============================================================ -->
    <!-- ============================================================
         TC_XML_037 | Multiple Products with Additional Images
         Product A: 2 additional images | Product B: 3 additional images
         Expected: Each product displays only its own images
         ============================================================ -->
    <!-- ============================================================
         TC_XML_038 | Image Order Preservation
         Input   : img3 → img1 → img2 (intentionally out of sequence)
         Expected: Output preserves img3, img1, img2 sequence exactly
         ============================================================ -->
    <!-- ============================================================
         TC_XML_039 | Additional Image Link Mixed with image_link
         Input   : image_link (main) + three g:additional_image_link nodes
         Expected: Main image in image_link column; others in additional_image_link column
         ============================================================ -->
    <!-- ============================================================
         TC_XML_040 | Large Number of Image Links
         Input   : 20 g:additional_image_link nodes
         Expected: All 20 image URLs captured without loss
         ============================================================ -->
    <!-- ============================================================
         TC_XML_041 | Similar Node Names
         Input   : <title>Samsung Galaxy S25</title> + <g:short_title>Galaxy S25</g:short_title>
         Expected: Title column = "Samsung Galaxy S25"; Short Title column = "Galaxy S25"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_042 | Similar Repeated Nodes
         Input   : title repeated twice + g:short_title repeated twice
         Expected: Values remain in their respective columns; no cross-population
         ============================================================ -->
    <!-- ============================================================
         TC_XML_043 | Description and Short Description Separation
         Input   : description + g:short_description nodes
         Expected: Values appear in their correct respective columns
         ============================================================ -->
    <!-- ============================================================
         TC_XML_044 | Similar Node Names with Same Value
         Input   : title = "Samsung" AND g:short_title = "Samsung"
         Expected: Both columns populated independently with "Samsung"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_045 | Similar Node Names with Partial Match
         Input   : title, g:product_title, g:short_title all present
         Expected: Each node mapped to its configured column only; no substring matching
         ============================================================ -->
    <!-- ============================================================
         TC_XML_046 | Repeated Title and Repeated Short Title
         Input   : title×2 + g:short_title×2
         Expected: Title column = "Title Value One,Title Value Two"
                   Short Title column = "Short Title One,Short Title Two"
                   (each column aggregates only its own node values)
         ============================================================ -->
    <!-- ============================================================
         TC_XML_047 | Similar Image Nodes
         Input   : image_link + two g:additional_image_link nodes
         Expected: image_link and g:additional_image_link mapped to separate columns
         ============================================================ -->
    <!-- ============================================================
         TC_XML_048 | Similar Custom Attributes
         Input   : g:color=Red + g:color_family=Warm Colors
         Expected: g:color → Color column = "Red"
                   g:color_family → Color Family column = "Warm Colors"
         ============================================================ -->
    <!-- ============================================================
         TC_XML_049 | Node Names with Common Prefix
         Input   : product_type + product_category
         Expected: Values stored independently in their respective columns
         ============================================================ -->
    <!-- ============================================================
         TC_XML_050 | Cross-Column Contamination Validation (Full)
         Input   : title, g:short_title, image_link, g:additional_image_link,
                   description, g:short_description, g:color(×2), g:size(×2)
         Expected: Every column contains ONLY values from its own XML node
         ============================================================ -->
    </channel>
</rss>
